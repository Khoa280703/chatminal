# Chatminal daemon endpoint (UDS on Linux/macOS, named pipe on Windows)
CHATMINAL_DAEMON_ENDPOINT=/tmp/chatminald.sock
CHATMINAL_DATA_DIR=/tmp/chatminal-data

# Daemon defaults
CHATMINAL_PREVIEW_LINES=1000
CHATMINAL_MAX_LINES_PER_SESSION=5000
CHATMINAL_DEFAULT_SHELL=/bin/bash
CHATMINAL_DEFAULT_COLS=120
CHATMINAL_DEFAULT_ROWS=32
CHATMINAL_HEALTH_INTERVAL_MS=5000
CHATMINAL_INPUT_PIPELINE_MODE=wezterm
CHATMINAL_WINDOW_BACKEND=wezterm-gui
CHATMINAL_WEZTERM_BIN=
# Internal test/smoke marker for legacy egui window bootstrap
CHATMINAL_LEGACY_WINDOW_READY_FILE=
CHATMINAL_BENCH_ENFORCE_HARD_GATE=1
CHATMINAL_BENCH_PROFILE=release
CHATMINAL_BENCH_SHELL=/bin/sh
CHATMINAL_BENCH_MAX_SECONDS=180
CHATMINAL_BENCH_SAMPLE_INTERVAL_SECONDS=0.02
CHATMINAL_FIDELITY_STRICT=1
CHATMINAL_FIDELITY_REQUIRED_CASES=bash-prompt,ctrl-c,ctrl-z,alt-backspace,meta-shortcuts-macos,unicode,resize,reconnect
CHATMINAL_SOAK_MODE=pr
CHATMINAL_SOAK_DURATION_SECONDS=7200
CHATMINAL_SOAK_PR_ITERATIONS=2
CHATMINAL_SOAK_WARMUP_ITERATIONS=
CHATMINAL_SOAK_BENCH_SAMPLES=40
CHATMINAL_SOAK_BENCH_WARMUP=8
CHATMINAL_SOAK_BENCH_TIMEOUT_MS=2000
CHATMINAL_SOAK_BENCH_SHELL=/bin/sh
CHATMINAL_SOAK_REQUIRE_BENCH_HARD_GATE=0
CHATMINAL_TIMEOUT_BIN=
